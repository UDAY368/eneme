DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h
PORT=4000
NODE_ENV=development

# Deployed frontend URL for CORS (e.g. https://eneme-sigma.vercel.app)
FRONTEND_URL=http://localhost:3000

# Optional: extra comma-separated CORS origins
CORS_ORIGIN=
